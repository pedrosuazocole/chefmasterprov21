<!DOCTYPE html>
<html lang="es-HN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Producto Terminado - Sistema de Cocina</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <header class="page-header">
            <h1>📦 Inventario de Producto Terminado</h1>
            <p class="subtitle">Controlá el stock de platos listos para venta</p>
        </header>
        
        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('stock')">Stock Actual</button>
            <button class="tab-btn" onclick="switchTab('movimientos')">📋 Kardex PT</button>
            <button class="tab-btn" onclick="switchTab('salida')">Registrar Salida</button>
            <% if (isAdmin) { %>
            <button class="tab-btn" onclick="switchTab('ajuste')">Ajuste de Inventario</button>
            <% } %>
        </div>
        
        <!-- TAB STOCK ACTUAL -->
        <div id="tab-stock" class="tab-content active">
            <div class="card">
                <div class="card-header">
                    <h3>Platos en Stock</h3>
                </div>
                <div class="card-body">
                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label>🔍 Buscar Plato</label>
                        <input type="text" id="buscarProducto" placeholder="Buscar por nombre de plato..." 
                               onkeyup="buscarProductoTerminado()" class="form-control">
                    </div>
                    
                    <% if (productoTerminado && productoTerminado.length > 0) { %>
                        <div class="table-container">
                            <table class="table" id="tablaProductoTerminado">
                                <thead>
                                    <tr>
                                        <th>Plato</th>
                                        <th>Stock</th>
                                        <th>Costo Unit.</th>
                                        <th>Precio Venta</th>
                                        <th>Valor Total</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyProductoTerminado">
                                    <% 
                                    let totalValor = 0;
                                    productoTerminado.forEach(p => { 
                                        const costoU  = parseFloat(p.costoUnitario || 0);
                                        const precioV = parseFloat(p.precioVenta   || 0);
                                        const valorTotal = p.cantidad * costoU;
                                        const valorVenta = p.cantidad * precioV;
                                        totalValor += valorTotal;
                                    %>
                                    <tr>
                                        <td><strong><%= p.plato %></strong></td>
                                        <td>
                                            <span class="badge" style="background: <%= p.cantidad > 0 ? '#21c354' : '#ff4b4b' %>; color: white;">
                                                <%= p.cantidad %> unidades
                                            </span>
                                        </td>
                                        <td>L. <%= costoU.toFixed(2) %></td>
                                        <td><strong>L. <%= precioV.toFixed(2) %></strong></td>
                                        <td>
                                            <div>Costo: L. <%= valorTotal.toFixed(2) %></div>
                                            <div style="color: #21c354; font-weight: bold;">Venta: L. <%= valorVenta.toFixed(2) %></div>
                                        </td>
                                        <td>
                                            <span style="font-size:0.85rem;color:#888;">
                                                Usá la pestaña<br>
                                                <strong>Registrar Salida</strong>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                                <tfoot>
                                    <tr style="background: var(--light); font-weight: bold;">
                                        <td colspan="4" style="text-align: right;">VALOR TOTAL INVENTARIO:</td>
                                        <td colspan="2">L. <%= totalValor.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',') %></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    <% } else { %>
                        <div style="text-align: center; padding: 3rem;">
                            <p class="text-muted">No hay producto terminado en stock</p>
                            <p class="text-muted" style="font-size: 0.9rem;">
                                El producto terminado se agrega automáticamente cuando procesás una producción
                            </p>
                            <a href="/produccion" class="btn btn-primary" style="margin-top: 1rem;">
                                Ir a Producción
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <!-- Resumen -->
            <div class="metrics-grid" style="margin-top: 1.5rem;">
                <div class="metric-card">
                    <div class="metric-icon">📦</div>
                    <div class="metric-content">
                        <h3>Tipos de Platos</h3>
                        <p class="metric-value"><%= productoTerminado.length %></p>
                    </div>
                </div>
                <div class="metric-card">
                    <div class="metric-icon">🍽️</div>
                    <div class="metric-content">
                        <h3>Unidades Totales</h3>
                        <p class="metric-value"><%= productoTerminado.reduce((sum, p) => sum + p.cantidad, 0) %></p>
                    </div>
                </div>
                <div class="metric-card">
                    <div class="metric-icon">💰</div>
                    <div class="metric-content">
                        <h3>Valor en Costo</h3>
                        <p class="metric-value">L. <%= productoTerminado.reduce((sum, p) => sum + (p.cantidad * p.costoUnitario), 0).toFixed(2) %></p>
                    </div>
                </div>
                <div class="metric-card">
                    <div class="metric-icon">💵</div>
                    <div class="metric-content">
                        <h3>Valor en Venta</h3>
                        <p class="metric-value">L. <%= productoTerminado.reduce((sum, p) => sum + (p.cantidad * p.precioVenta), 0).toFixed(2) %></p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- TAB KARDEX PRODUCTO TERMINADO -->
        <div id="tab-movimientos" class="tab-content">
            <div class="card">
                <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
                    <h3>📋 Kardex de Producto Terminado</h3>
                    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                        <button class="btn btn-sm" onclick="window.print()" style="background:#555;color:white;">🖨️ Imprimir</button>
                        <button class="btn btn-sm" onclick="exportarSalidaExcel()" style="background:#21c354;color:white;">📊 Excel</button>
                        <button class="btn btn-sm" onclick="exportarSalidaPDF()" style="background:#ff4b4b;color:white;">📄 PDF</button>
                        <select id="filtroMovPlato" onchange="filtrarMovimientos()" 
                                style="padding:0.4rem 0.8rem;border:1px solid var(--border);border-radius:6px;">
                            <option value="">Todos los platos</option>
                            <% productoTerminado.forEach(p => { %>
                                <option value="<%= p.plato %>"><%= p.plato %></option>
                            <% }); %>
                        </select>
                        <select id="filtroMovTipo" onchange="filtrarMovimientos()"
                                style="padding:0.4rem 0.8rem;border:1px solid var(--border);border-radius:6px;">
                            <option value="">Todos los tipos</option>
                            <option value="ENTRADA">📥 Entradas</option>
                            <option value="SALIDA">📤 Salidas</option>
                        </select>
                    </div>
                </div>
                <div class="card-body">
                    <%
                    const totalEntradasPT = movimientos.filter(m=>m.tipo==='ENTRADA').reduce((s,m)=>s+parseInt(m.cantidad||0),0);
                    const totalSalidasPT  = movimientos.filter(m=>m.tipo==='SALIDA').reduce((s,m)=>s+parseInt(m.cantidad||0),0);
                    %>
                    <!-- Resumen rápido -->
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;">
                        <div style="background:#f0fff4;border:1px solid #21c354;border-radius:8px;padding:1rem;text-align:center;">
                            <div style="font-size:1.5rem;">📥</div>
                            <div style="font-weight:bold;color:#21c354;font-size:1.2rem;"><%= totalEntradasPT %></div>
                            <div style="font-size:0.85rem;color:#666;">Total Entradas (unidades)</div>
                        </div>
                        <div style="background:#fff5f5;border:1px solid #ff4b4b;border-radius:8px;padding:1rem;text-align:center;">
                            <div style="font-size:1.5rem;">📤</div>
                            <div style="font-weight:bold;color:#ff4b4b;font-size:1.2rem;"><%= totalSalidasPT %></div>
                            <div style="font-size:0.85rem;color:#666;">Total Salidas (unidades)</div>
                        </div>
                        <div style="background:#f0f4ff;border:1px solid #0068c9;border-radius:8px;padding:1rem;text-align:center;">
                            <div style="font-size:1.5rem;">📦</div>
                            <div style="font-weight:bold;color:#0068c9;font-size:1.2rem;"><%= totalEntradasPT - totalSalidasPT %></div>
                            <div style="font-size:0.85rem;color:#666;">Saldo Neto (unidades)</div>
                        </div>
                    </div>

                    <% if (movimientos && movimientos.length > 0) { %>
                        <div class="table-container">
                            <table class="table" id="tablaMovPT">
                                <thead>
                                    <tr style="background:#f8f9fa;">
                                        <th>Fecha y Hora</th>
                                        <th>Plato</th>
                                        <th>Tipo</th>
                                        <th style="color:#21c354;">📥 Entrada</th>
                                        <th style="color:#ff4b4b;">📤 Salida</th>
                                        <th>Stock Anterior</th>
                                        <th>Stock Nuevo</th>
                                        <th>Origen / Motivo</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyMovPT">
                                    <% movimientos.forEach(m => { 
                                        const esEntrada = m.tipo === 'ENTRADA';
                                    %>
                                    <tr style="background:<%= esEntrada ? '#f0fff4' : m.tipo==='SALIDA' ? '#fff5f5' : '#f0f4ff' %>;"
                                        data-plato="<%= m.plato %>" data-tipo="<%= m.tipo %>">
                                        <td style="white-space:nowrap;font-size:0.85rem;">
                                            <%= new Date(m.fecha).toLocaleDateString('es-HN') %><br>
                                            <small style="color:#999;"><%= new Date(m.fecha).toLocaleTimeString('es-HN',{hour:'2-digit',minute:'2-digit'}) %></small>
                                        </td>
                                        <td><strong><%= m.plato %></strong></td>
                                        <td>
                                            <span style="background:<%= esEntrada ? '#21c354' : m.tipo==='SALIDA' ? '#ff4b4b' : '#0068c9' %>;
                                                         color:white;padding:0.25rem 0.6rem;border-radius:12px;font-size:0.82rem;white-space:nowrap;">
                                                <%= esEntrada ? '📥 ENTRADA' : m.tipo==='SALIDA' ? '📤 SALIDA' : '🔧 '+m.tipo %>
                                            </span>
                                        </td>
                                        <td style="color:#21c354;font-weight:bold;text-align:center;">
                                            <%= esEntrada ? parseInt(m.cantidad) : '—' %>
                                        </td>
                                        <td style="color:#ff4b4b;font-weight:bold;text-align:center;">
                                            <%= m.tipo==='SALIDA' ? parseInt(m.cantidad) : '—' %>
                                        </td>
                                        <td style="text-align:center;"><%= m.stockAnterior ?? '-' %></td>
                                        <td style="text-align:center;"><strong><%= m.stockNuevo ?? '-' %></strong></td>
                                        <td><small style="color:#666;"><%= m.origen || m.motivo || '-' %></small></td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <p style="margin-top:0.5rem;font-size:0.85rem;color:#999;text-align:right;">
                            Total movimientos: <%= movimientos.length %>. Entradas primero, luego salidas.
                        </p>
                    <% } else { %>
                        <div style="text-align:center;padding:3rem;color:#999;">
                            <div style="font-size:3rem;">📋</div>
                            <p>No hay movimientos registrados aún</p>
                            <p style="font-size:0.9rem;">Se registran al procesar producciones o registrar salidas</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
        
        <!-- TAB REGISTRAR SALIDA -->
        <div id="tab-salida" class="tab-content">
            <div class="card">
                <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
                    <h3>Registrar Salida de Producto</h3>
                    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                        <button class="btn btn-sm" onclick="imprimirMovimientos()"
                                style="background:#555;color:white;padding:0.4rem 0.8rem;">🖨️ Imprimir</button>
                        <button class="btn btn-sm" onclick="exportarSalidaExcel()"
                                style="background:#21c354;color:white;padding:0.4rem 0.8rem;">📊 Excel</button>
                        <button class="btn btn-sm" onclick="exportarSalidaPDF()"
                                style="background:#ff4b4b;color:white;padding:0.4rem 0.8rem;">📄 PDF</button>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Formulario nueva salida -->
                    <form id="formSalida" onsubmit="registrarSalida(event)">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Plato</label>
                                <select id="platoSalida" required onchange="actualizarStockDisponible()">
                                    <option value="">Seleccionar plato...</option>
                                    <% productoTerminado.forEach(p => { %>
                                        <option value="<%= p.plato %>" data-stock="<%= p.cantidad %>">
                                            <%= p.plato %> (Stock: <%= p.cantidad %>)
                                        </option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Cantidad</label>
                                <input type="number" id="cantidadSalida" min="1" step="1" required>
                                <small id="stockDisponible" class="text-muted"></small>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Motivo de Salida</label>
                            <select id="motivoSalida" required>
                                <option value="Venta">Venta</option>
                                <option value="Consumo interno">Consumo interno</option>
                                <option value="Degustación">Degustación</option>
                                <option value="Merma">Merma</option>
                                <option value="Donación">Donación</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">📤 Registrar Salida</button>
                    </form>

                    <!-- Historial de salidas registradas -->
                    <hr style="margin:1.5rem 0;border:none;border-top:1px solid #eee;">
                    <h4 style="margin-bottom:1rem;">📋 Salidas Registradas</h4>

                    <%
                    const soloSalidas = movimientos
                        .filter(m => m.tipo === 'SALIDA')
                        .sort((a,b) => new Date(b.fecha) - new Date(a.fecha));
                    %>

                    <% if (soloSalidas.length > 0) { %>
                    <div class="table-container">
                        <table class="table" style="font-size:0.88rem;" id="tablaSalidas">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Plato</th>
                                    <th>Cantidad</th>
                                    <th>Motivo</th>
                                    <th>Stock Ant.</th>
                                    <th>Stock Nuevo</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                            <% soloSalidas.forEach(s => { %>
                            <tr>
                                <td style="white-space:nowrap;font-size:0.82rem;">
                                    <%= new Date(s.fecha).toLocaleDateString('es-HN') %><br>
                                    <small style="color:#999;"><%= new Date(s.fecha).toLocaleTimeString('es-HN',{hour:'2-digit',minute:'2-digit'}) %></small>
                                </td>
                                <td><strong><%= s.plato %></strong></td>
                                <td style="text-align:center;">
                                    <span style="background:#fff5f5;color:#ff4b4b;padding:0.2rem 0.5rem;border-radius:8px;font-weight:bold;">
                                        -<%= s.cantidad %>
                                    </span>
                                </td>
                                <td><small style="color:#666;"><%= s.motivo || s.origen || '-' %></small></td>
                                <td style="text-align:center;color:#888;"><%= s.stockAnterior ?? '-' %></td>
                                <td style="text-align:center;"><strong><%= s.stockNuevo ?? '-' %></strong></td>
                                <td style="white-space:nowrap;">
                                    <% if (s.id && (s.motivo || s.origen || '').match(/Venta|Consumo|Degustación|Merma|Donación|Otro/i)) { %>
                                    <button class="btn-editar-salida"
                                            data-id="<%= s.id %>"
                                            data-plato="<%= s.plato %>"
                                            data-cantidad="<%= s.cantidad %>"
                                            data-motivo="<%= s.motivo || s.origen || 'Venta' %>"
                                            style="background:#0068c9;color:white;border:none;border-radius:6px;padding:0.25rem 0.55rem;cursor:pointer;font-size:0.82rem;margin-right:0.25rem;">
                                        ✏️
                                    </button>
                                    <button class="btn-eliminar-salida"
                                            data-id="<%= s.id %>"
                                            data-plato="<%= s.plato %>"
                                            data-cantidad="<%= s.cantidad %>"
                                            style="background:#ff4b4b;color:white;border:none;border-radius:6px;padding:0.25rem 0.55rem;cursor:pointer;font-size:0.82rem;">
                                        🗑️
                                    </button>
                                    <% } else { %>
                                    <small style="color:#bbb;">Sistema</small>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <p style="text-align:center;color:#999;padding:1.5rem;">No hay salidas registradas aún.</p>
                    <% } %>
                </div>
            </div>
        </div>
        
        <!-- TAB AJUSTE (Solo Admin) -->
        <% if (isAdmin) { %>
        <div id="tab-ajuste" class="tab-content">
            <div class="card">
                <div class="card-header">
                    <h3>⚠️ Ajuste de Inventario (Solo Admin)</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>Atención:</strong> Esta función permite ajustar el stock manualmente.
                        Usala solo para correcciones de inventario.
                    </div>
                    
                    <form id="formAjuste" onsubmit="realizarAjuste(event)">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Plato</label>
                                <select id="platoAjuste" required onchange="mostrarStockActual()">
                                    <option value="">Seleccionar plato...</option>
                                    <% productoTerminado.forEach(p => { %>
                                        <option value="<%= p.plato %>" data-stock="<%= p.cantidad %>">
                                            <%= p.plato %>
                                        </option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Nueva Cantidad</label>
                                <input type="number" id="nuevaCantidad" min="0" step="1" required>
                                <small id="stockActual" class="text-muted"></small>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label>Motivo del Ajuste</label>
                            <input type="text" id="motivoAjuste" required 
                                   placeholder="Ej: Conteo físico, Corrección de error">
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-block">
                            🔧 Realizar Ajuste
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <% } %>
    </main>
    
    <script src="/js/main.js"></script>
    <script src="/js/producto-terminado.js"></script>
    <script>
    function filtrarMovimientos() {
        const plato = document.getElementById('filtroMovPlato').value;
        const tipo  = document.getElementById('filtroMovTipo').value;
        document.querySelectorAll('#tbodyMovPT tr').forEach(fila => {
            const okPlato = !plato || fila.dataset.plato === plato;
            const okTipo  = !tipo  || fila.dataset.tipo  === tipo;
            fila.style.display = (okPlato && okTipo) ? '' : 'none';
        });
    }
    function imprimirMovimientos() { window.open('/api/exportar/movimientos-pt/pdf', '_blank'); }
    function exportarSalidaExcel() { window.location.href = '/api/exportar/movimientos-pt/excel'; }
    function exportarSalidaPDF()   { window.open('/api/exportar/movimientos-pt/pdf', '_blank'); }

    // ── EDITAR / ELIMINAR SALIDAS ────────────────────────────
    document.addEventListener('DOMContentLoaded', function() {
        document.addEventListener('click', function(e) {
            const btnEd = e.target.closest('.btn-editar-salida');
            const btnEl = e.target.closest('.btn-eliminar-salida');
            if (btnEd) abrirEditarSalida(btnEd);
            if (btnEl) confirmarEliminarSalida(btnEl);
        });
        document.getElementById('modalEditarSalida').addEventListener('click', function(e) {
            if (e.target === this) cerrarModalSalida();
        });
    });

    function abrirEditarSalida(btn) {
        document.getElementById('editSalidaId').value    = btn.dataset.id;
        document.getElementById('editSalidaPlato').value = btn.dataset.plato;
        document.getElementById('editSalidaCant').value  = btn.dataset.cantidad;
        const sel = document.getElementById('editSalidaMotivo');
        for (let o of sel.options) { if (o.value === btn.dataset.motivo) { o.selected = true; break; } }
        document.getElementById('modalEditarSalida').style.display = 'flex';
    }
    function cerrarModalSalida() { document.getElementById('modalEditarSalida').style.display = 'none'; }

    async function guardarEdicionSalida() {
        const id      = document.getElementById('editSalidaId').value;
        const plato   = document.getElementById('editSalidaPlato').value;
        const cantidad= parseInt(document.getElementById('editSalidaCant').value);
        const motivo  = document.getElementById('editSalidaMotivo').value;
        const btn     = document.getElementById('btnGuardarSalida');
        if (!cantidad || cantidad < 1) { showNotification('Cantidad inválida','error'); return; }
        if (!confirm(`¿Confirmar edición?\nPlato: ${plato}\nNueva cantidad: ${cantidad}\n⚠️ Se recalculará el stock.`)) return;
        btn.disabled = true; btn.textContent = '⏳ Guardando...';
        try {
            const r = await fetch(`/producto-terminado/salida/${id}`, {
                method: 'PUT', headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ cantidad, motivo })
            });
            const data = await r.json();
            if (data.success) { showNotification('✅ Salida actualizada','success'); cerrarModalSalida(); setTimeout(()=>location.reload(),1500); }
            else { showNotification(data.error||'Error','error'); btn.disabled=false; btn.textContent='💾 Guardar'; }
        } catch(e) { showNotification('Error de conexión','error'); btn.disabled=false; btn.textContent='💾 Guardar'; }
    }

    async function confirmarEliminarSalida(btn) {
        const id=btn.dataset.id, plato=btn.dataset.plato, cantidad=btn.dataset.cantidad;
        if (!confirm(`¿Eliminar salida?\nPlato: ${plato}\nCantidad: ${cantidad}\n⚠️ Se devolverá la cantidad al stock.`)) return;
        try {
            const r = await fetch(`/producto-terminado/salida/${id}`, { method: 'DELETE' });
            const data = await r.json();
            if (data.success) { showNotification('✅ Salida eliminada y stock restaurado','success'); setTimeout(()=>location.reload(),1500); }
            else showNotification(data.error||'Error al eliminar','error');
        } catch(e) { showNotification('Error de conexión','error'); }
    }
    </script>

    <!-- MODAL EDITAR SALIDA -->
    <div id="modalEditarSalida" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);
         z-index:9999;align-items:center;justify-content:center;padding:1rem;">
        <div style="background:white;border-radius:14px;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
            <div style="background:linear-gradient(135deg,#0068c9,#004a8f);padding:1.2rem 1.5rem;
                        display:flex;justify-content:space-between;align-items:center;border-radius:14px 14px 0 0;">
                <h3 style="margin:0;color:white;font-size:1rem;">✏️ Editar Salida</h3>
                <button onclick="cerrarModalSalida()" style="background:rgba(255,255,255,0.2);border:none;color:white;border-radius:50%;width:28px;height:28px;cursor:pointer;">✕</button>
            </div>
            <div style="padding:1.5rem;">
                <input type="hidden" id="editSalidaId">
                <div class="form-group" style="margin-bottom:1rem;">
                    <label style="font-weight:600;display:block;margin-bottom:0.35rem;">Plato</label>
                    <input type="text" id="editSalidaPlato" readonly style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:7px;background:#f5f5f5;box-sizing:border-box;">
                </div>
                <div class="form-group" style="margin-bottom:1rem;">
                    <label style="font-weight:600;display:block;margin-bottom:0.35rem;">Nueva Cantidad *</label>
                    <input type="number" id="editSalidaCant" min="1" style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:7px;box-sizing:border-box;">
                </div>
                <div class="form-group" style="margin-bottom:1.25rem;">
                    <label style="font-weight:600;display:block;margin-bottom:0.35rem;">Motivo</label>
                    <select id="editSalidaMotivo" style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:7px;box-sizing:border-box;">
                        <option value="Venta">Venta</option>
                        <option value="Consumo interno">Consumo interno</option>
                        <option value="Degustación">Degustación</option>
                        <option value="Merma">Merma</option>
                        <option value="Donación">Donación</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
                <div style="background:#fff3cd;border-radius:7px;padding:0.65rem;margin-bottom:1rem;font-size:0.85rem;">⚠️ Se recalculará el stock del producto terminado.</div>
                <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
                    <button onclick="cerrarModalSalida()" style="padding:0.6rem 1.2rem;border:1px solid #ddd;border-radius:7px;cursor:pointer;background:white;">Cancelar</button>
                    <button id="btnGuardarSalida" onclick="guardarEdicionSalida()" style="padding:0.6rem 1.4rem;background:#0068c9;color:white;border:none;border-radius:7px;cursor:pointer;font-weight:bold;">💾 Guardar</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
