<!DOCTYPE html>
<html lang="es-HN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportes - Sistema de Cocina</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <header class="page-header">
            <h1>📈 Reportes y Análisis</h1>
            <p class="subtitle">Información clave para tomar decisiones</p>
        </header>
        
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-icon">💰</div>
                <div class="metric-content">
                    <h3>Valor Total Inventario</h3>
                    <p class="metric-value">L. <%= totalInventario.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',') %></p>
                </div>
            </div>
            
            <div class="metric-card <%= stockBajo.length > 0 ? 'alert-card' : '' %>">
                <div class="metric-icon">⚠️</div>
                <div class="metric-content">
                    <h3>Productos con Stock Bajo</h3>
                    <p class="metric-value"><%= stockBajo.length %></p>
                </div>
            </div>
            
            <div class="metric-card">
                <div class="metric-icon">🍽️</div>
                <div class="metric-content">
                    <h3>Recetas Activas</h3>
                    <p class="metric-value"><%= recetas.length %></p>
                </div>
            </div>
            
            <div class="metric-card">
                <div class="metric-icon">📊</div>
                <div class="metric-content">
                    <h3>Producciones Total</h3>
                    <p class="metric-value"><%= produccion.length %></p>
                </div>
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
            <div class="card">
                <div class="card-header">
                    <h3>⚠️ Alertas de Stock Bajo</h3>
                </div>
                <div class="card-body">
                    <% if (stockBajo.length > 0) { %>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Ingrediente</th>
                                    <th>Stock</th>
                                    <th>Mínimo</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% stockBajo.forEach(item => { %>
                                <tr>
                                    <td><strong><%= item.ingrediente %></strong></td>
                                    <td style="color: #ff4b4b; font-weight: bold;"><%= parseFloat(item.stock||0).toFixed(2) %> <%= item.unidad %></td>
                                    <td><%= item.stockMinimo %></td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <p class="text-center text-muted" style="padding: 2rem;">
                            ✅ Todos los productos tienen stock suficiente
                        </p>
                    <% } %>
                </div>
            </div>
            
            <div class="card">
                <div class="card-header">
                    <h3>💰 Top 5 Recetas Rentables</h3>
                </div>
                <div class="card-body">
                    <% if (topRecetas.length > 0) { %>
                        <% topRecetas.forEach((r, index) => { %>
                            <div style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <div>
                                        <div style="font-size: 1.5rem; font-weight: bold; color: var(--primary);">
                                            #<%= index + 1 %>
                                        </div>
                                        <div style="font-weight: 600;"><%= r.plato %></div>
                                        <div style="font-size: 0.85rem; color: #666;">
                                            Margen: <%= (parseFloat(r.margenUtilidad||0) * 100).toFixed(1) %>%
                                        </div>
                                    </div>
                                    <div style="text-align: right;">
                                        <div style="font-size: 1.25rem; font-weight: bold; color: #21c354;">
                                            L. <%= parseFloat(r.valorUtilidad||0).toFixed(2) %>
                                        </div>
                                        <div style="font-size: 0.85rem; color: #666;">
                                            utilidad/plato
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-center text-muted" style="padding: 2rem;">
                            No hay recetas creadas aún
                        </p>
                    <% } %>
                </div>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
                <h3>📦 Inventario Completo</h3>
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                    <button class="btn btn-sm" onclick="window.print()" style="background:#555;color:white;">🖨️ Imprimir</button>
                    <button class="btn btn-sm" onclick="exportarExcel('inventario','inventario')" style="background:#21c354;color:white;">📊 Excel</button>
                    <button class="btn btn-sm" onclick="window.open('/api/exportar/catalogo/pdf','_blank')" style="background:#ff4b4b;color:white;">📄 PDF</button>
                </div>
            </div>
            <div class="card-body">
                <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
                    <input type="text" id="filtroInvReporte" placeholder="🔍 Buscar ingrediente..."
                           oninput="filtrarInvReporte()"
                           style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:6px;width:240px;">
                    <select id="filtroStockInv" onchange="filtrarInvReporte()"
                            style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:6px;">
                        <option value="">Todos los stocks</option>
                        <option value="bajo">⚠️ Stock bajo</option>
                        <option value="ok">✅ Stock normal</option>
                        <option value="cero">🔴 Sin stock</option>
                    </select>
                    <span id="contInv" style="font-size:0.85rem;color:#888;"></span>
                </div>
                <table class="table" id="tablaInvReporte">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Ingrediente</th>
                            <th>Stock</th>
                            <th>Unidad</th>
                            <th style="background:#fffbf0;color:#856404;">Costo Promedio</th>
                            <th>Valor Total</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyInv">
                        <% inventario.forEach(item => {
                            const valorTotal = item.stock * item.costoUnitario;
                            const estado = item.stock === 0 ? 'cero' : item.stock < (item.stockMinimo||0) ? 'bajo' : 'ok';
                        %>
                        <tr class="fila-inv-reporte"
                            data-nombre="<%= (item.ingrediente||'').toLowerCase() %>"
                            data-estado="<%= estado %>">
                            <td><code style="background:#f0f4ff;padding:0.1rem 0.4rem;border-radius:4px;font-size:0.82rem;"><%= item.codigo %></code></td>
                            <td><strong><%= item.ingrediente %></strong></td>
                            <td style="font-weight:bold;color:<%= estado==='cero'?'#ff4b4b':estado==='bajo'?'#ff9800':'#21c354' %>"><%= parseFloat(item.stock).toFixed(2) %></td>
                            <td><span style="background:#e8f4fd;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.82rem;"><%= item.unidad %></span></td>
                            <td style="background:#fffbf0;font-weight:bold;color:#856404;">L. <%= item.costoUnitario.toFixed(4) %></td>
                            <td><strong style="color:#0068c9;">L. <%= valorTotal.toFixed(2) %></strong></td>
                            <td>
                                <% if (estado === 'cero') { %>
                                    <span style="background:#ff4b4b;color:white;padding:0.15rem 0.5rem;border-radius:8px;font-size:0.78rem;">SIN STOCK</span>
                                <% } else if (estado === 'bajo') { %>
                                    <span style="background:#ff9800;color:white;padding:0.15rem 0.5rem;border-radius:8px;font-size:0.78rem;">STOCK BAJO</span>
                                <% } else { %>
                                    <span style="background:#21c354;color:white;padding:0.15rem 0.5rem;border-radius:8px;font-size:0.78rem;">OK</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                    <tfoot>
                        <tr style="background:var(--light);font-weight:bold;">
                            <td colspan="5" style="text-align:right;">TOTAL INVENTARIO:</td>
                            <td>L. <%= totalInventario.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,',') %></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
                <!-- Paginación -->
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:1rem;flex-wrap:wrap;gap:0.5rem;">
                    <div style="display:flex;gap:0.4rem;" id="paginaInv"></div>
                    <select id="porPaginaInv" onchange="filtrarInvReporte()"
                            style="padding:0.35rem 0.6rem;border:1px solid #ddd;border-radius:5px;font-size:0.85rem;">
                        <option value="10">10 por página</option>
                        <option value="20" selected>20 por página</option>
                        <option value="50">50 por página</option>
                        <option value="9999">Ver todos</option>
                    </select>
                </div>
            </div>
        </div>
        

        <% if (recetas.length > 0) { %>
        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
                <h3>📊 Detalle de Costeo por Receta</h3>
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                    <button class="btn btn-sm" onclick="window.print()" style="background:#555;color:white;">🖨️ Imprimir</button>
                    <button class="btn btn-sm" onclick="exportarExcel('recetas','recetas')" style="background:#21c354;color:white;">📊 Excel</button>
                    <button class="btn btn-sm" onclick="exportarPDF('recetas','recetas')" style="background:#ff4b4b;color:white;">📄 PDF</button>
                </div>
            </div>
            <div class="card-body">
                <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
                    <input type="text" id="filtroRecetasReporte" placeholder="🔍 Buscar plato..."
                           oninput="filtrarRecetasReporte()"
                           style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:6px;width:230px;">
                    <select id="filtroMargenRec" onchange="filtrarRecetasReporte()"
                            style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:6px;">
                        <option value="">Todos los márgenes</option>
                        <option value="bajo">⚠️ Margen bajo (&lt; 50%)</option>
                        <option value="ok">✅ Margen OK (≥ 50%)</option>
                    </select>
                    <span id="contRec" style="font-size:0.85rem;color:#888;"></span>
                </div>
                <table class="table" id="tablaRecetasReporte">
                    <thead>
                        <tr>
                            <th>Plato</th>
                            <th>Costo (L.)</th>
                            <th>Precio Venta (L.)</th>
                            <th>Utilidad (L.)</th>
                            <th>Margen %</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyRec">
                        <% recetas.forEach(function(r) {
                            var margen = parseFloat(r.margenUtilidad * 100);
                            var estRec = margen >= 50 ? 'ok' : 'bajo';
                        %>
                        <tr class="fila-receta-reporte"
                            data-plato="<%= (r.plato||'').toLowerCase() %>"
                            data-margen="<%= estRec %>">
                            <td><strong><%= r.plato %></strong></td>
                            <td>L. <%= parseFloat(r.costoTotalPlato).toFixed(2) %></td>
                            <td>L. <%= parseFloat(r.precioVenta).toFixed(2) %></td>
                            <td style="color:#21c354;font-weight:bold;">L. <%= parseFloat(r.valorUtilidad).toFixed(2) %></td>
                            <td>
                                <span style="background:<%= margen>=50?'#21c354':'#ff4b4b' %>;color:white;padding:0.15rem 0.5rem;border-radius:8px;font-size:0.82rem;font-weight:bold;">
                                    <%= margen.toFixed(1) %>%
                                </span>
                            </td>
                            <td><%= margen>=50?'✅ OK':'⚠️ Revisar' %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:1rem;flex-wrap:wrap;gap:0.5rem;">
                    <div style="display:flex;gap:0.4rem;" id="paginaRec"></div>
                    <select id="porPaginaRec" onchange="filtrarRecetasReporte()"
                            style="padding:0.35rem 0.6rem;border:1px solid #ddd;border-radius:5px;font-size:0.85rem;">
                        <option value="10" selected>10 por página</option>
                        <option value="20">20 por página</option>
                        <option value="9999">Ver todos</option>
                    </select>
                </div>
            </div>
        </div>
        <% } %>

        <!-- SECCIÓN MOVIMIENTOS DE KARDEX -->
        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
                <h3>📋 Movimientos de Kardex</h3>
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                    <button class="btn btn-sm" onclick="window.print()" style="background:#555;color:white;">🖨️ Imprimir</button>
                    <button class="btn btn-sm" onclick="exportarExcel('kardex','kardex')" style="background:#21c354;color:white;">📊 Excel</button>
                </div>
            </div>
            <div class="card-body">
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0.75rem;margin-bottom:1rem;">
                    <div class="form-group" style="margin:0;">
                        <label>Fecha Inicio</label>
                        <input type="date" id="repKardexFechaI" onchange="filtrarKardexReporte()">
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label>Fecha Final</label>
                        <input type="date" id="repKardexFechaF" onchange="filtrarKardexReporte()">
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label>Producto</label>
                        <input type="text" id="repKardexProd" placeholder="Producto..." onkeyup="filtrarKardexReporte()">
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label>Tipo</label>
                        <select id="repKardexTipo" onchange="filtrarKardexReporte()">
                            <option value="">Todos</option>
                            <option value="ENTRADA">📥 Entrada</option>
                            <option value="SALIDA">📤 Salida</option>
                        </select>
                    </div>
                </div>
                <% if (kardex && kardex.length > 0) { %>
                <div class="table-container">
                    <table class="table" style="font-size:0.9rem;">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Producto</th>
                                <th>Tipo</th>
                                <th>Documento</th>
                                <th style="color:#21c354;">📥 Entrada</th>
                                <th style="color:#ff4b4b;">📤 Salida</th>
                                <th>Costo Unit.</th>
                                <th>Saldo</th>
                                <th>Observaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% kardex.forEach((k, idx) => {
                                const esEntrada = k.tipo === 'ENTRADA';
                            %>
                            <tr style="background:<%= esEntrada ? '#f0fff4' : '#fff5f5' %>;"
                                class="fila-kardex-rep"
                                data-producto="<%= (k.producto||'').toLowerCase() %>"
                                data-tipo="<%= k.tipo %>"
                                data-fecha="<%= new Date(k.fecha).toISOString().split('T')[0] %>">                                <td style="color:#999;font-size:0.82rem;"><%= idx + 1 %></td>
                                <td style="white-space:nowrap;font-size:0.85rem;">
                                    <%= new Date(k.fecha).toLocaleDateString('es-HN') %><br>
                                    <small style="color:#999;"><%= new Date(k.fecha).toLocaleTimeString('es-HN',{hour:'2-digit',minute:'2-digit'}) %></small>
                                </td>
                                <td><strong><%= k.producto %></strong></td>
                                <td>
                                    <span style="background:<%= esEntrada ? '#21c354' : '#ff4b4b' %>;color:white;
                                                 padding:0.2rem 0.55rem;border-radius:12px;font-size:0.8rem;">
                                        <%= esEntrada ? '📥 ENTRADA' : '📤 SALIDA' %>
                                    </span>
                                </td>
                                <td><code style="background:#f0f4ff;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.8rem;"><%= k.documento %></code></td>
                                <td style="color:#21c354;font-weight:bold;text-align:center;">
                                    <%= esEntrada ? parseFloat(k.cantidad).toFixed(2) : '—' %>
                                </td>
                                <td style="color:#ff4b4b;font-weight:bold;text-align:center;">
                                    <%= !esEntrada ? parseFloat(k.cantidad).toFixed(2) : '—' %>
                                </td>
                                <td style="text-align:right;">L. <%= parseFloat(k.costoUnitario||0).toFixed(2) %></td>
                                <td style="text-align:right;"><strong><%= parseFloat(k.stockNuevo||0).toFixed(2) %></strong></td>
                                <td style="font-size:0.82rem;color:#666;"><%= k.observaciones || '—' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <!-- Paginación Kardex -->
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:1rem;flex-wrap:wrap;gap:0.5rem;">
                    <div style="display:flex;gap:0.4rem;" id="paginaKardex"></div>
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <span id="contKardex" style="font-size:0.85rem;color:#888;"></span>
                        <select id="porPaginaKardex" onchange="filtrarKardexReporte()"
                                style="padding:0.35rem 0.6rem;border:1px solid #ddd;border-radius:5px;font-size:0.85rem;">
                            <option value="15" selected>15 por página</option>
                            <option value="30">30 por página</option>
                            <option value="50">50 por página</option>
                            <option value="9999">Ver todos</option>
                        </select>
                    </div>
                </div>
                <% } else { %>
                <div style="text-align:center;padding:2rem;color:#999;">
                    <div style="font-size:2.5rem;">📋</div>
                    <p>No hay movimientos de Kardex registrados aún.</p>
                </div>
                <% } %>
            </div>
        </div>

    </main>

    <script src="/js/main.js"></script>
    <script src="/js/exportar.js"></script>
    <script>
    // ══════════════════════════════════════════════════════
    // UTILIDAD DE PAGINACIÓN — reutilizable
    // ══════════════════════════════════════════════════════
    function paginar(todasFilas, paginaActual, porPagina, contenedorId) {
        const total    = todasFilas.length;
        const totalPag = Math.ceil(total / porPagina);
        const inicio   = (paginaActual - 1) * porPagina;
        const fin      = Math.min(inicio + porPagina, total);

        // Mostrar/ocultar filas de esta página
        todasFilas.forEach((fila, i) => {
            fila.style.display = (i >= inicio && i < fin) ? '' : 'none';
        });

        // Renderizar botones de página
        const contenedor = document.getElementById(contenedorId);
        if (!contenedor) return;
        contenedor.innerHTML = '';

        if (totalPag <= 1) return;

        const btnStyle = (activo) =>
            `padding:0.3rem 0.65rem;border:1px solid ${activo?'#0068c9':'#ddd'};border-radius:5px;cursor:pointer;` +
            `background:${activo?'#0068c9':'white'};color:${activo?'white':'#333'};font-size:0.82rem;`;

        // Anterior
        if (paginaActual > 1) {
            const btn = document.createElement('button');
            btn.textContent = '‹';
            btn.style.cssText = btnStyle(false);
            btn.onclick = () => contenedor.dataset.pagActual = (paginaActual - 1);
            contenedor.appendChild(btn);
        }

        // Páginas (máx. 7 botones)
        const rango = 3;
        for (let p = Math.max(1, paginaActual - rango); p <= Math.min(totalPag, paginaActual + rango); p++) {
            const btn = document.createElement('button');
            btn.textContent = p;
            btn.style.cssText = btnStyle(p === paginaActual);
            btn.onclick = () => { contenedor.dataset.pagActual = p; };
            contenedor.appendChild(btn);
        }

        // Siguiente
        if (paginaActual < totalPag) {
            const btn = document.createElement('button');
            btn.textContent = '›';
            btn.style.cssText = btnStyle(false);
            btn.onclick = () => contenedor.dataset.pagActual = (paginaActual + 1);
            contenedor.appendChild(btn);
        }

        return { inicio: inicio + 1, fin, total };
    }

    // Observer para re-renderizar al cambiar de página vía dataset
    function observarPaginacion(contenedorId, callbackFiltrar) {
        const el = document.getElementById(contenedorId);
        if (!el) return;
        el.dataset.pagActual = 1;
        new MutationObserver(() => callbackFiltrar()).observe(el, { attributes: true, attributeFilter: ['data-pag-actual'] });
    }

    // ══════════════════════════════════════════════════════
    // FILTROS CON PAGINACIÓN
    // ══════════════════════════════════════════════════════

    // INVENTARIO
    function filtrarInvReporte() {
        const busq  = (document.getElementById('filtroInvReporte')?.value || '').toLowerCase();
        const stock = document.getElementById('filtroStockInv')?.value || '';
        const pp    = parseInt(document.getElementById('porPaginaInv')?.value || 20);
        const pag   = parseInt(document.getElementById('paginaInv')?.dataset.pagActual || 1);

        const todasFilas = [...document.querySelectorAll('.fila-inv-reporte')].filter(f => {
            const okBusq  = !busq  || (f.dataset.nombre||'').includes(busq);
            const okStock = !stock || f.dataset.estado === stock;
            const ok = okBusq && okStock;
            f.style.display = ok ? '' : 'none'; // marcar visibles
            return ok;
        });

        const r = paginar(todasFilas, pag, pp, 'paginaInv');
        const cnt = document.getElementById('contInv');
        if (cnt) cnt.textContent = `${todasFilas.length} resultado(s)`;
    }

    // RECETAS
    function filtrarRecetasReporte() {
        const busq   = (document.getElementById('filtroRecetasReporte')?.value || '').toLowerCase();
        const margen = document.getElementById('filtroMargenRec')?.value || '';
        const pp     = parseInt(document.getElementById('porPaginaRec')?.value || 10);
        const pag    = parseInt(document.getElementById('paginaRec')?.dataset.pagActual || 1);

        const todasFilas = [...document.querySelectorAll('.fila-receta-reporte')].filter(f => {
            const okBusq  = !busq   || (f.dataset.plato||'').includes(busq);
            const okMarg  = !margen || f.dataset.margen === margen;
            return okBusq && okMarg;
        });

        paginar(todasFilas, pag, pp, 'paginaRec');
        const cnt = document.getElementById('contRec');
        if (cnt) cnt.textContent = `${todasFilas.length} resultado(s)`;

        // Ocultar las que no pasaron filtro
        document.querySelectorAll('.fila-receta-reporte').forEach(f => {
            if (!todasFilas.includes(f)) f.style.display = 'none';
        });
    }

    // KARDEX
    function filtrarKardexReporte() {
        const fi   = document.getElementById('repKardexFechaI')?.value || '';
        const ff   = document.getElementById('repKardexFechaF')?.value || '';
        const prod = (document.getElementById('repKardexProd')?.value || '').toLowerCase().trim();
        const tipo = document.getElementById('repKardexTipo')?.value || '';
        const pp   = parseInt(document.getElementById('porPaginaKardex')?.value || 15);
        const pag  = parseInt(document.getElementById('paginaKardex')?.dataset.pagActual || 1);

        const todasFilas = [...document.querySelectorAll('.fila-kardex-rep')].filter(f => {
            const okFi   = !fi   || (f.dataset.fecha||'') >= fi;
            const okFf   = !ff   || (f.dataset.fecha||'') <= ff;
            const okProd = !prod || (f.dataset.producto||'').includes(prod);
            const okTipo = !tipo || f.dataset.tipo === tipo;
            return okFi && okFf && okProd && okTipo;
        });

        paginar(todasFilas, pag, pp, 'paginaKardex');
        const cnt = document.getElementById('contKardex');
        if (cnt) cnt.textContent = `${todasFilas.length} movimiento(s)`;

        document.querySelectorAll('.fila-kardex-rep').forEach(f => {
            if (!todasFilas.includes(f)) f.style.display = 'none';
        });
    }

    // ── B3: REPORTES FINANCIEROS ─────────────────────────
    async function consultarReporteFinanciero() {
        const mes = document.getElementById('mesFin').value;
        const btn = document.getElementById('btnConsultarFin');
        btn.disabled = true; btn.textContent = '⏳ Calculando...';
        try {
            const r = await fetch(`/api/reportes/financieros${mes ? '?mes='+mes : ''}`);
            const d = await r.json();
            renderReporteFinanciero(d);
        } catch(e) {
            showNotification('Error al consultar reporte financiero', 'error');
        } finally {
            btn.disabled = false; btn.textContent = '📊 Consultar';
        }
    }

    function fmt(n) { return 'L. ' + parseFloat(n||0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,','); }

    function renderReporteFinanciero(d) {
        const cp = d.estadoCostoProd;
        const cv = d.estadoCostoVentas;

        document.getElementById('finPeriodo').textContent    = d.periodo === 'Acumulado' ? 'Acumulado General' : d.periodo;
        document.getElementById('finAnio').textContent       = d.anio;

        // Estado Costo Producción
        document.getElementById('finInvInicialProd').textContent  = fmt(cp.invInicialProd);
        document.getElementById('finComprasMes').textContent      = fmt(cp.totalComprasMes);
        document.getElementById('finDisponibles').textContent     = fmt(cp.disponibilidadMes);
        document.getElementById('finInvFinalProd').textContent    = fmt(cp.invFinalProd);
        document.getElementById('finCostoProd').textContent       = fmt(cp.costoProdMes);
        document.getElementById('finComprasAnio').textContent     = fmt(cp.totalComprasAnio);

        // Estado Costo Ventas
        document.getElementById('finInvInicialPT').textContent    = fmt(cv.invInicialPT);
        document.getElementById('finEntradasPT').textContent      = fmt(cv.totalEntradasPTMes);
        document.getElementById('finPTDisponible').textContent    = fmt(cv.ptDisponible);
        document.getElementById('finInvFinalPT').textContent      = fmt(cv.invFinalPT);
        document.getElementById('finCostoVentas').textContent     = fmt(cv.costoVentasPT);
        document.getElementById('finSalidasMes').textContent      = cv.totalSalidasMes + ' uds.';
        document.getElementById('finSalidasAnio').textContent     = cv.totalSalidasAnio + ' uds.';

        document.getElementById('reporteFinanciero').style.display = 'block';
    }
    </script>

    <!-- SECCIÓN: REPORTES FINANCIEROS -->
    <div class="card" style="border-top:3px solid #0068c9;">
        <div class="card-header" style="background:linear-gradient(135deg,#f0f4ff,#e8eeff);">
            <h3 style="color:#0068c9;">💼 Reportes Financieros</h3>
        </div>
        <div class="card-body">
            <div style="display:flex;align-items:flex-end;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
                <div class="form-group" style="margin:0;">
                    <label style="font-weight:600;">Mes a Consultar</label>
                    <input type="month" id="mesFin"
                           style="padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:7px;font-size:0.95rem;">
                    <small style="display:block;color:#888;margin-top:0.2rem;">Vacío = acumulado general</small>
                </div>
                <button id="btnConsultarFin" onclick="consultarReporteFinanciero()"
                        style="padding:0.6rem 1.5rem;background:#0068c9;color:white;border:none;border-radius:7px;cursor:pointer;font-weight:bold;height:42px;">
                    📊 Consultar
                </button>
            </div>

            <div id="reporteFinanciero" style="display:none;">
                <div style="background:#f8f9fa;border-radius:8px;padding:0.6rem 1rem;margin-bottom:1.5rem;display:flex;gap:2rem;font-size:0.9rem;color:#555;">
                    <span>📅 Período: <strong id="finPeriodo"></strong></span>
                    <span>📆 Año: <strong id="finAnio"></strong></span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1rem;">

                    <!-- Estado Costo de Producción -->
                    <div style="border:1px solid #0068c9;border-radius:10px;overflow:hidden;">
                        <div style="background:#0068c9;color:white;padding:0.75rem 1rem;">
                            <strong>📦 Estado de Costo de Producción</strong>
                        </div>
                        <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
                            <tbody>
                            <tr style="border-bottom:1px solid #eee;">
                                <td style="padding:0.6rem 1rem;color:#555;">Inventario Inicial de Insumos</td>
                                <td style="padding:0.6rem 1rem;text-align:right;" id="finInvInicialProd">—</td>
                            </tr>
                            <tr style="border-bottom:1px solid #eee;background:#f0f9ff;">
                                <td style="padding:0.6rem 1rem;color:#555;">+ Compras del Período</td>
                                <td style="padding:0.6rem 1rem;text-align:right;font-weight:bold;color:#21c354;" id="finComprasMes">—</td>
                            </tr>
                            <tr style="border-bottom:2px solid #0068c9;background:#e8f4ff;">
                                <td style="padding:0.6rem 1rem;font-weight:bold;">= Disponibilidad Total</td>
                                <td style="padding:0.6rem 1rem;text-align:right;font-weight:bold;color:#0068c9;" id="finDisponibles">—</td>
                            </tr>
                            <tr style="border-bottom:1px solid #eee;">
                                <td style="padding:0.6rem 1rem;color:#555;">- Inventario Final de Insumos</td>
                                <td style="padding:0.6rem 1rem;text-align:right;color:#ff4b4b;" id="finInvFinalProd">—</td>
                            </tr>
                            <tr style="background:#f0fff4;">
                                <td style="padding:0.75rem 1rem;font-weight:bold;font-size:1rem;">= COSTO DE PRODUCCIÓN</td>
                                <td style="padding:0.75rem 1rem;text-align:right;font-weight:bold;font-size:1.05rem;color:#21c354;" id="finCostoProd">—</td>
                            </tr>
                            <tr style="border-top:2px solid #eee;background:#fafafa;">
                                <td style="padding:0.5rem 1rem;font-size:0.85rem;color:#888;">📆 Compras Acumuladas Año</td>
                                <td style="padding:0.5rem 1rem;text-align:right;font-size:0.85rem;color:#888;" id="finComprasAnio">—</td>
                            </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Estado Costo de Ventas PT -->
                    <div style="border:1px solid #21c354;border-radius:10px;overflow:hidden;">
                        <div style="background:#21c354;color:white;padding:0.75rem 1rem;">
                            <strong>🍽️ Estado de Costo de Ventas (PT)</strong>
                        </div>
                        <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
                            <tbody>
                            <tr style="border-bottom:1px solid #eee;">
                                <td style="padding:0.6rem 1rem;color:#555;">Inventario Inicial Producto Terminado</td>
                                <td style="padding:0.6rem 1rem;text-align:right;" id="finInvInicialPT">—</td>
                            </tr>
                            <tr style="border-bottom:1px solid #eee;background:#f0fff4;">
                                <td style="padding:0.6rem 1rem;color:#555;">+ Entradas de Producción</td>
                                <td style="padding:0.6rem 1rem;text-align:right;font-weight:bold;color:#21c354;" id="finEntradasPT">—</td>
                            </tr>
                            <tr style="border-bottom:2px solid #21c354;background:#e6ffe6;">
                                <td style="padding:0.6rem 1rem;font-weight:bold;">= PT Disponible para Venta</td>
                                <td style="padding:0.6rem 1rem;text-align:right;font-weight:bold;color:#21c354;" id="finPTDisponible">—</td>
                            </tr>
                            <tr style="border-bottom:1px solid #eee;">
                                <td style="padding:0.6rem 1rem;color:#555;">- Inventario Final PT</td>
                                <td style="padding:0.6rem 1rem;text-align:right;color:#ff4b4b;" id="finInvFinalPT">—</td>
                            </tr>
                            <tr style="background:#f0fff4;">
                                <td style="padding:0.75rem 1rem;font-weight:bold;font-size:1rem;">= COSTO DE VENTAS PT</td>
                                <td style="padding:0.75rem 1rem;text-align:right;font-weight:bold;font-size:1.05rem;color:#0068c9;" id="finCostoVentas">—</td>
                            </tr>
                            <tr style="border-top:2px solid #eee;background:#fafafa;">
                                <td style="padding:0.5rem 1rem;font-size:0.85rem;color:#888;">Unidades Vendidas (Período)</td>
                                <td style="padding:0.5rem 1rem;text-align:right;font-size:0.85rem;color:#888;" id="finSalidasMes">—</td>
                            </tr>
                            <tr style="background:#fafafa;">
                                <td style="padding:0.5rem 1rem;font-size:0.85rem;color:#888;">📆 Unidades Vendidas (Acumulado Año)</td>
                                <td style="padding:0.5rem 1rem;text-align:right;font-size:0.85rem;color:#888;" id="finSalidasAnio">—</td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         PANEL DE REPORTES DE VENTAS
    ══════════════════════════════════════════════════ -->
    <div class="card" style="border-top:3px solid #21c354;margin-top:1.5rem;">
        <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;background:linear-gradient(135deg,#f0fff4,#e6ffe6);">
            <h3 style="color:#21c354;">🛒 Panel de Reportes de Ventas</h3>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                <button class="btn btn-sm" onclick="window.print()" style="background:#555;color:white;">🖨️ Imprimir</button>
                <a href="/api/exportar/ventas/xlsx" class="btn btn-sm" style="background:#21c354;color:white;text-decoration:none;">📊 Exportar Excel</a>
            </div>
        </div>
        <div class="card-body">

            <!-- Filtros de período -->
            <div style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1.5rem;padding:1rem;background:#f9f9f9;border-radius:8px;">
                <div class="form-group" style="margin:0;">
                    <label style="font-weight:600;font-size:0.88rem;">Desde</label>
                    <input type="date" id="ventasDesde" style="padding:0.5rem;border:1px solid #ddd;border-radius:6px;">
                </div>
                <div class="form-group" style="margin:0;">
                    <label style="font-weight:600;font-size:0.88rem;">Hasta</label>
                    <input type="date" id="ventasHasta" style="padding:0.5rem;border:1px solid #ddd;border-radius:6px;">
                </div>
                <button onclick="filtrarVentas()" style="padding:0.5rem 1.2rem;background:#21c354;color:white;border:none;border-radius:6px;cursor:pointer;font-weight:bold;">🔍 Filtrar</button>
                <button onclick="limpiarFiltroVentas()" style="padding:0.5rem 1rem;background:#999;color:white;border:none;border-radius:6px;cursor:pointer;">🔄 Limpiar</button>
            </div>

            <!-- KPIs de ventas -->
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:1.5rem;">
                <div style="background:#f0fff4;border:1px solid #21c354;border-radius:8px;padding:1rem;text-align:center;">
                    <div style="font-size:1.5rem;font-weight:bold;color:#21c354;" id="kpiIngresos">
                        L. <%= totalVentasIngresos.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,',') %>
                    </div>
                    <div style="font-size:0.82rem;color:#666;">Ingresos Totales</div>
                </div>
                <div style="background:#f0f4ff;border:1px solid #0068c9;border-radius:8px;padding:1rem;text-align:center;">
                    <div style="font-size:1.5rem;font-weight:bold;color:#0068c9;" id="kpiUnidades">
                        <%= totalVentasUnidades %>
                    </div>
                    <div style="font-size:0.82rem;color:#666;">Unidades Vendidas</div>
                </div>
                <div style="background:#fff5f5;border:1px solid #ff4b4b;border-radius:8px;padding:1rem;text-align:center;">
                    <div style="font-size:1.5rem;font-weight:bold;color:#ff4b4b;">
                        <%= ventasPorPlatillo.length %>
                    </div>
                    <div style="font-size:0.82rem;color:#666;">Platillos Vendidos</div>
                </div>
                <div style="background:#fffbf0;border:1px solid #ff9800;border-radius:8px;padding:1rem;text-align:center;">
                    <div style="font-size:1.5rem;font-weight:bold;color:#ff9800;">
                        <%= ventasPorMes.length %>
                    </div>
                    <div style="font-size:0.82rem;color:#666;">Meses con Ventas</div>
                </div>
            </div>

            <!-- Ventas por Platillo -->
            <h4 style="margin-bottom:0.75rem;">🍽️ Ventas por Platillo</h4>
            <% if (ventasPorPlatillo.length > 0) { %>
            <div class="table-container" style="margin-bottom:2rem;">
                <table class="table" id="tablaVentasPlatillo">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Platillo</th>
                            <th style="text-align:right;">Uds. Vendidas</th>
                            <th style="text-align:right;">Ingresos (L.)</th>
                            <th style="text-align:right;">Costo Total (L.)</th>
                            <th style="text-align:right;">Utilidad (L.)</th>
                            <th style="text-align:center;">Margen %</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyVentasPlatillo">
                    <% ventasPorPlatillo.forEach((p, i) => {
                        const margen = p.ingresos > 0 ? (p.utilidad/p.ingresos*100) : 0;
                    %>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="color:#999;font-size:0.82rem;">
                                <span style="background:<%= i===0?'#ffd700':i===1?'#c0c0c0':i===2?'#cd7f32':'#f0f4ff' %>;padding:0.15rem 0.45rem;border-radius:8px;font-weight:bold;">
                                    <%= i+1 %>
                                </span>
                            </td>
                            <td><strong><%= p.plato %></strong></td>
                            <td style="text-align:right;font-weight:bold;color:#0068c9;"><%= p.unidades %></td>
                            <td style="text-align:right;font-weight:bold;color:#21c354;">L. <%= p.ingresos.toFixed(2) %></td>
                            <td style="text-align:right;color:#ff9800;">L. <%= p.costoTotal.toFixed(2) %></td>
                            <td style="text-align:right;font-weight:bold;">L. <%= p.utilidad.toFixed(2) %></td>
                            <td style="text-align:center;">
                                <span style="background:<%= margen>=50?'#21c354':'#ff4b4b' %>;color:white;padding:0.15rem 0.5rem;border-radius:8px;font-size:0.82rem;font-weight:bold;">
                                    <%= margen.toFixed(1) %>%
                                </span>
                            </td>
                        </tr>
                    <% }); %>
                    </tbody>
                    <tfoot>
                        <tr style="background:#f0fff4;font-weight:bold;border-top:2px solid #21c354;">
                            <td colspan="2">TOTALES</td>
                            <td style="text-align:right;"><%= totalVentasUnidades %></td>
                            <td style="text-align:right;color:#21c354;">L. <%= totalVentasIngresos.toFixed(2) %></td>
                            <td style="text-align:right;color:#ff9800;">L. <%= ventasPorPlatillo.reduce((s,p)=>s+p.costoTotal,0).toFixed(2) %></td>
                            <td style="text-align:right;">L. <%= ventasPorPlatillo.reduce((s,p)=>s+p.utilidad,0).toFixed(2) %></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <% } else { %>
            <div style="text-align:center;padding:2rem;color:#999;margin-bottom:1.5rem;">
                <div style="font-size:2.5rem;">🛒</div>
                <p>No hay ventas registradas aún.</p>
            </div>
            <% } %>

            <!-- Ventas por Mes -->
            <h4 style="margin-bottom:0.75rem;">📅 Ventas por Mes (Acumulado)</h4>
            <% if (ventasPorMes.length > 0) { %>
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Período</th>
                            <th style="text-align:right;">Uds. Vendidas</th>
                            <th style="text-align:right;">Ingresos (L.)</th>
                            <th>% del Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% ventasPorMes.forEach(m => {
                        const pct = totalVentasIngresos > 0 ? (m.ingresos/totalVentasIngresos*100) : 0;
                    %>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td><strong><%= m.mes %></strong></td>
                            <td style="text-align:right;font-weight:bold;color:#0068c9;"><%= m.unidades %></td>
                            <td style="text-align:right;font-weight:bold;color:#21c354;">L. <%= m.ingresos.toFixed(2) %></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:0.5rem;">
                                    <div style="flex:1;background:#e0e0e0;border-radius:4px;height:8px;overflow:hidden;">
                                        <div style="width:<%= pct.toFixed(1) %>%;background:#21c354;height:100%;border-radius:4px;"></div>
                                    </div>
                                    <span style="font-size:0.82rem;color:#666;min-width:40px;"><%= pct.toFixed(1) %>%</span>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <p style="text-align:center;color:#999;padding:1rem;">Sin datos por mes.</p>
            <% } %>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        observarPaginacion('paginaInv', filtrarInvReporte);
        filtrarInvReporte();
        observarPaginacion('paginaRec', filtrarRecetasReporte);
        filtrarRecetasReporte();
        observarPaginacion('paginaKardex', filtrarKardexReporte);
        filtrarKardexReporte();
    });

    async function filtrarVentas() {
        const desde = document.getElementById('ventasDesde').value;
        const hasta = document.getElementById('ventasHasta').value;
        try {
            let url = '/api/reportes/ventas';
            const params = new URLSearchParams();
            if (desde) params.set('desde', desde);
            if (hasta) params.set('hasta', hasta);
            if (params.toString()) url += '?' + params.toString();

            const r = await fetch(url);
            const d = await r.json();

            // Actualizar KPIs
            document.getElementById('kpiIngresos').textContent =
                'L. ' + d.totales.totalIngresos.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,',');
            document.getElementById('kpiUnidades').textContent = d.totales.totalUnidades;

            // Actualizar tabla por platillo
            const tbody = document.getElementById('tbodyVentasPlatillo');
            if (tbody) {
                tbody.innerHTML = d.porPlatillo.map((p, i) => {
                    const margen = p.ingresos > 0 ? (p.utilidad/p.ingresos*100) : 0;
                    const col = i===0?'#ffd700':i===1?'#c0c0c0':i===2?'#cd7f32':'#f0f4ff';
                    return `<tr style="border-bottom:1px solid #f0f0f0;">
                        <td><span style="background:${col};padding:0.15rem 0.45rem;border-radius:8px;font-weight:bold;">${i+1}</span></td>
                        <td><strong>${p.plato}</strong></td>
                        <td style="text-align:right;font-weight:bold;color:#0068c9;">${p.unidades}</td>
                        <td style="text-align:right;font-weight:bold;color:#21c354;">L. ${p.ingresos.toFixed(2)}</td>
                        <td style="text-align:right;color:#ff9800;">L. ${p.costoTotal.toFixed(2)}</td>
                        <td style="text-align:right;font-weight:bold;">L. ${p.utilidad.toFixed(2)}</td>
                        <td style="text-align:center;">
                            <span style="background:${margen>=50?'#21c354':'#ff4b4b'};color:white;padding:0.15rem 0.5rem;border-radius:8px;font-size:0.82rem;font-weight:bold;">${margen.toFixed(1)}%</span>
                        </td>
                    </tr>`;
                }).join('');
            }
            showNotification('✅ Ventas filtradas', 'success');
        } catch(e) {
            showNotification('Error al filtrar ventas', 'error');
        }
    }

    function limpiarFiltroVentas() {
        document.getElementById('ventasDesde').value = '';
        document.getElementById('ventasHasta').value = '';
        location.reload();
    }
    </script>
</body>
</html>
